# AutoMind AI 配置示例文件
# 复制此文件为 .env 并填入实际值

# LLM 配置 - API Key (从系统环境变量 API_KEY 读取)
# 注意: API_KEY 已在系统环境变量中设置,无需在此重复
# API_KEY=your_api_key_here

# 主要模型: DeepSeek V4
DEEPSEEK_API_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 辅助模型: Ollama Qwen3.5 9B
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b

# 默认使用的模型 (primary 或 assistant)
DEFAULT_MODEL=deepseek-chat

# 通用配置
TEMPERATURE=0.7
MAX_TOKENS=2000

# 应用配置
APP_NAME=AutoMind AI
APP_VERSION=0.1.0
DEBUG=True

# 数据库配置
# SQLite (开发测试)
# DATABASE_URL=sqlite:///./automind.db

# PostgreSQL (生产环境)
DATABASE_URL=postgresql://username:password@localhost:5432/automind


# Redis 缓存配置
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# 爬虫配置
REQUEST_TIMEOUT=30
MAX_RETRIES=3

# 搜索 — 使用免费 DuckDuckGo，无需 API Key
