# ============================================
# AutoMind AI - Docker 环境变量模板
# 复制为 .env（已 gitignore）并填入真实密钥
#   cp .env.docker .env
# ============================================

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=automind
# --- Redis ---
REDIS_CACHE_TTL=3600

# --- 网络代理（DuckDuckGo 需要代理访问）---
# 改成你实际的代理端口
# 用 Docker 时用 host.docker.internal
# DDG_PROXY=http://host.docker.internal:7890

# --- LLM / API 密钥（必填）---
API_KEY=sk-your-deepseek-key
# --- LLM 设置 ---
DEEPSEEK_API_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEFAULT_MODEL=primary
TEMPERATURE=0.7
MAX_TOKENS=2000

# --- Ollama（可选，使用宿主机上的 ollama）---
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3.5:9b

# --- 应用设置 ---
APP_NAME=AutoMind AI
APP_VERSION=0.1.0
DEBUG=false
SECRET_KEY=generate-a-random-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALLOWED_ORIGINS=["*"]

# --- 外部端口（如果主机端口冲突可修改）---
# POSTGRES_EXTERNAL_PORT=5432
# REDIS_EXTERNAL_PORT=6379
# BACKEND_EXTERNAL_PORT=8000
# FRONTEND_EXTERNAL_PORT=3000
